# Supabase project settings (Project Settings > API di dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Hanya dipakai di server (API routes), jangan pernah expose ke client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL publik aplikasi, dipakai untuk membangun link verifikasi email
NEXT_PUBLIC_APP_URL=https://mitratitip.vercel.app

# Mailgun (email verifikasi) - https://app.mailgun.com/mg/dashboard
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=MitraTitip <no-reply@mg.yourdomain.com>

# Midtrans (pembayaran tagihan platform) - https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# Dipakai Vercel Cron untuk otorisasi panggilan ke /api/billing/generate
CRON_SECRET=generate-random-string-yourself
